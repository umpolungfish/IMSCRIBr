# Folio → section mapping from the Phytoglyphica engine spec
SECTIONS = [
    'botanical',       # f1–f66
    'astronomical',    # f67–f73
    'cosmological',    # f68 foldout (special)
    'pharmaceutical',  # f99–f102
    'balneological',   # f75–f84
    'recipe',          # f103r+
]

SECTION_BOUNDARIES: list[tuple[str, int, int | None]] = [
    ('botanical',      1,  66),
    ('astronomical',  67,  73),
    ('cosmological',  68,  68),   # foldout — special handling
    ('balneological',  75,  84),
    ('pharmaceutical', 87, 102),  # includes f87 (pharma foldout) + f99–f102
    ('recipe',        103, None),  # f103+
]

# For text sections: f67–f73 astronomical, f75–f84 balneological, f103+ recipe
# For phytoglyphica: f1–f66 botanical, f87–f102 pharmaceutical


def classify_folio(folio: str) -> str:
    """Assign folio to section using Voynich_Phytoglyphica boundaries."""
    m = re.match(r'f(\d+)', folio)
    if not m:
        return 'botanical'
    n = int(m.group(1))
    if n <= 66:
        return 'botanical'
    if n <= 73:
        if n == 68:
            return 'cosmological'
        return 'astronomical'
    if n <= 84:
        return 'balneological'
    if n <= 102:
        return 'pharmaceutical'
    return 'recipe'

# ============================================================================
# IVTFF PARSING — Full Glyph Inventory
# ============================================================================

LOC_RE = re.compile(r'^<(f(\d+)\w*)[.,]')


def _parse_eva_word_full(raw: str) -> list[int] | None:
    """Parse an EVA word into a list of token indices using the FULL glyph inventory.

    Handles trigraphs (cth, ckh, cph, cfh, tch, sch) and digraphs (ch, sh)
    before single-character glyphs. Unknown glyphs get FALLBACK_TOKEN.
    """
    cleaned = re.sub(r'[!*%{}&=\-\s\d;:?@()\[\]<>/]', '', raw)
    if not cleaned:
        return None
    # Remove leading/trailing non-glyph characters
    cleaned = cleaned.strip("'\"\\|$#")
    if not cleaned:
        return None

    tokens: list[int] = []
    i = 0
    while i < len(cleaned):
        matched = False
        # Try trigraphs first
        for dg in ['cth', 'ckh', 'cph', 'cfh', 'tch', 'sch']:
            if cleaned[i:i+3] == dg and dg in EVA_GLYPHS:
                tokens.append(EVA_GLYPHS[dg][0])
                i += 3
                matched = True
                break
        if matched:
            continue
        # Try digraphs
        for dg in ['ch', 'sh', 'ck', 'ct', 'cf', 'cp', 'sc', 'tc', 'kh', 'ph', 'th']:
            if cleaned[i:i+2] == dg and dg in EVA_GLYPHS:
                tokens.append(EVA_GLYPHS[dg][0])
                i += 2
                matched = True
                break
        if matched:
            continue
        # Single glyph
        g = cleaned[i]
        if g in EVA_GLYPHS:
            tokens.append(EVA_GLYPHS[g][0])
        else:
            tokens.append(FALLBACK_TOKEN)
        i += 1

    return tokens if tokens else None


def _parse_eva_word_12(raw: str) -> list[int] | None:
    """Parse an EVA word into the 12-primitive IMASM token indices only.

    This is the original 12-glyph mapping. Non-primitive glyphs are discarded.
    Used for backward-compatible fingerprinting.
    """
    cleaned = re.sub(r'[!*%{}&=\-\s\d;:?@()\[\]<>/]', '', raw)
    if not cleaned:
        return None
    # Only keep the 12 primitive glyphs
    keep_chars: set[str] = set()
    for g in ['o','p','e','a','d','s','ch','sh','t','k','r','y']:
        keep_chars.add(g)
    # For digraphs, we need special handling
    tokens: list[int] = []
    i = 0
    prim_map = {g: EVA_GLYPHS[g][0] for g in ['o','p','e','a','d','s','ch','sh','t','k','r','y'] if g in EVA_GLYPHS}
    while i < len(cleaned):
        if cleaned[i:i+2] in prim_map:
            tokens.append(prim_map[cleaned[i:i+2]])
            i += 2
        elif cleaned[i] in prim_map:
            tokens.append(prim_map[cleaned[i]])
            i += 1
        else:
            i += 1
    return tokens if len(tokens) >= 2 else None


def parse_ivtff(path: str | Path, full_glyphs: bool = True) -> dict[str, list[list[int]]]:
    """Parse IVTFF transcription into per-section word lists.

    Args:
        path: Path to LSI_ivtff_0d.txt
        full_glyphs: If True, use the full 30-glyph inventory.
                     If False, use only the 12 primitive glyphs.
    """
    parse_fn = _parse_eva_word_full if full_glyphs else _parse_eva_word_12
    section_words: dict[str, list[list[int]]] = defaultdict(list)
    current_folio = 'f1r'
    with open(path, encoding='latin-1') as fh:
        for line in fh:
            line = line.strip()
            if not line or line.startswith('#'):
                continue
            m = LOC_RE.match(line)
            if m:
                current_folio = m.group(1)
                text = re.sub(r'^<[^>]+>\s*', '', line)
            else:
                text = line
            section = classify_folio(current_folio)
            for raw_word in text.split('.'):
                toks = parse_fn(raw_word)
                if toks:
                    section_words[section].append(toks)
    return dict(section_words)


# ============================================================================
# STATISTICS
# ============================================================================

class CorpusStats(NamedTuple):
    length_dist:  dict   # section → Counter[int]
    unigram:      dict   # section → Counter[int]
    bigrams:      dict   # section → dict[int, dict[int, float]]
    pos_freq:     dict   # section → {initial/medial/final: Counter}
    word_vocab:   dict   # section → Counter[tuple]
    global_vocab: Counter
    total_tokens: int    # NEW — total glyph tokens parsed


def _normalize(raw: dict) -> dict:
    total = sum(raw.values())
    return {k: v / total for k, v in raw.items()} if total else {}


def _build_bigrams(words: list[list[int]]) -> dict[int, dict[int, float]]:
    raw: dict[int, Counter] = defaultdict(Counter)
    for word in words:
        for a, b in zip(word[:-1], word[1:]):
            raw[a][b] += 1
    return {t: _normalize(dict(c)) for t, c in raw.items()}


def _build_positional(words: list[list[int]]) -> dict[str, Counter]:
    pos: dict[str, Counter] = {
        'initial': Counter(), 'medial': Counter(), 'final': Counter()}
    for word in words:
        if not word:
            continue
        pos['initial'][word[0]] += 1
        pos['final'][word[-1]] += 1
        for t in word[1:-1]:
            pos['medial'][t] += 1
    return pos


def extract_stats(section_words: dict[str, list[list[int]]]) -> CorpusStats:
    length_dist, unigram, bigrams, pos_freq, word_vocab = {}, {}, {}, {}, {}
    global_vocab: Counter = Counter()
    total_tokens = 0
    for sec, words in section_words.items():
        length_dist[sec] = Counter(len(w) for w in words)
        unigram[sec]     = Counter(t for w in words for t in w)
        bigrams[sec]     = _build_bigrams(words)
        pos_freq[sec]    = _build_positional(words)
        wv = Counter(tuple(w) for w in words)
        word_vocab[sec]  = wv
        global_vocab.update(wv)
        total_tokens += sum(len(w) for w in words)
    return CorpusStats(length_dist, unigram, bigrams, pos_freq, word_vocab,
                       global_vocab, total_tokens)

# ============================================================================
# METRICS
# ============================================================================

def zipf_exponent(freq: Counter) -> float:
    ranked = sorted(freq.values(), reverse=True)
    if len(ranked) < 5:
        return 1.0
    log_r = [math.log(i + 1) for i in range(len(ranked))]
    log_f = [math.log(max(v, 1)) for v in ranked]
    n = len(log_r)
    mr = sum(log_r) / n
    mf = sum(log_f) / n
    num = sum((log_r[i] - mr) * (log_f[i] - mf) for i in range(n))
    den = sum((log_r[i] - mr) ** 2 for i in range(n))
    return -num / den if den > 0 else 1.0


def bigram_entropy(matrix: dict, uni: Counter) -> float:
    total = sum(uni.values())
    if not total:
        return 0.0
    h = 0.0
    for tok, row in matrix.items():
        p_t = uni[tok] / total
        h_row = -sum(p * math.log2(p) for p in row.values() if p > 0)
        h += p_t * h_row
    return h


def type_token_ratio(words: list[list[int]]) -> float:
    if not words:
        return 0.0
    return len(set(tuple(w) for w in words)) / len(words)


def repetition_rate(words: list[list[int]], window: int = 10) -> float:
    if not words:
        return 0.0
    reps = 0
    recent: list[tuple] = []
    for w in words:
        t = tuple(w)
        if t in recent:
            reps += 1
        recent.append(t)
        if len(recent) > window:
            recent.pop(0)
    return reps / len(words)


def kl_divergence(p: Counter, q: Counter) -> float:
    vocab = set(p) | set(q)
    pt = sum(p.values()) + len(vocab)
    qt = sum(q.values()) + len(vocab)
    return sum(
        ((p.get(t, 0) + 1) / pt) *
        math.log2(((p.get(t, 0) + 1) / pt) / ((q.get(t, 0) + 1) / qt))
        for t in vocab
    )


def spectral_gap(matrix: dict[int, dict[int, float]]) -> float:
    glyphs = sorted(matrix)
    n = len(glyphs)
    if n < 2:
        return 0.0
    idx = {g: i for i, g in enumerate(glyphs)}
    pi = [1.0 / n] * n
    for _ in range(200):
        new_pi = [0.0] * n
        for gf in glyphs:
            for gt, prob in matrix.get(gf, {}).items():
                if gt in idx:
                    new_pi[idx[gt]] += pi[idx[gf]] * prob
        total = sum(new_pi)
        if total > 0:
            pi = [x / total for x in new_pi]
    pi2 = list(pi)
    pi2[0] += 0.01
    pi2[1] -= 0.01
    t2 = sum(pi2)
    pi2 = [x / t2 for x in pi2]
    decay = 0.0
    for _ in range(50):
        new2 = [0.0] * n
        for gf in glyphs:
            for gt, prob in matrix.get(gf, {}).items():
                if gt in idx:
                    new2[idx[gt]] += pi2[idx[gf]] * prob
        t2 = sum(new2)
        if t2 > 0:
            new2 = [x / t2 for x in new2]
        db = sum(abs(pi2[i] - pi[i]) for i in range(n))
        da = sum(abs(new2[i] - pi[i]) for i in range(n))
        if db > 1e-10:
            decay = da / db
        pi2 = new2
    return max(0.0, 1.0 - decay)


# ============================================================================
# IMSCRIBr FINGERPRINTING
# ============================================================================

def _dominant_cycle_8(matrix: dict[int, dict[int, float]]) -> tuple[int, ...] | None:
    """Greedy strongest closed cycle of length 8 in the bigram matrix."""
    best: list[int] = []
    best_geo = -1.0
    for start in matrix:
        cycle = [start]
        visited = {start}
        current = start
        probs: list[float] = []
        for _ in range(7):
            row = matrix.get(current, {})
            cands = sorted(
                ((g, p) for g, p in row.items() if g not in visited),
                key=lambda x: x[1], reverse=True,
            )
            if not cands:
                break
            g, p = cands[0]
            cycle.append(g)
            visited.add(g)
            probs.append(p)
            current = g
        close_p = matrix.get(current, {}).get(start, 0.0)
        probs.append(close_p)
        if len(cycle) == 8 and all(p > 0 for p in probs):
            geo = math.exp(sum(math.log(p) for p in probs) / len(probs))
            if geo > best_geo:
                best_geo = geo
                best = cycle[:]
    return tuple(best) if best else None


def section_fingerprint(words: list[list[int]]) -> tuple:
    """Return (StructuralFingerprint, nearest_canonical_name, coarse_key).

    Fingerprinting is restricted to the 12-primitive token set (0–11).
    Extended glyphs (12+) are mapped to IMSCRIB (5) for fingerprint purposes
    so the structural classifier sees a valid Token enum.
    """
    # Map tokens to 12-primitive subset for fingerprinting
    def _map_to_12(tok: int) -> int:
        if 0 <= tok <= 11:
            return tok
        return 5  # IMSCRIB as fallback for non-primitive glyphs

    words_12 = [[_map_to_12(t) for t in w] for w in words]
    matrix = _build_bigrams(words_12)
    arr = _dominant_cycle_8(matrix)
    if arr is None:
        stream = [t for w in words_12 for t in w]
        counts: Counter = Counter()
        for i in range(len(stream) - 7):
            counts[tuple(stream[i:i+8])] += 1
        arr = counts.most_common(1)[0][0] if counts else tuple(range(8))
    fp = compute_fingerprint(arr)
    canon = match_canonical(arr)
    if not canon:
        best_score, nearest = -1, None
        for cname, cfp in CANONICAL_FINGERPRINTS.items():
            score = (
                2 * (fp.frobenius_order == cfp.frobenius_order) +
                2 * (fp.dialetheia_complete == cfp.dialetheia_complete) +
                1 * (fp.self_ref == cfp.self_ref) +
                1 * (fp.sig_F == cfp.sig_F) +
                1 * (fp.sig_D == cfp.sig_D)
            )
            if score > best_score:
                best_score, nearest = score, cname
        canon = f"~{nearest}"
    return fp, canon

# ============================================================================
# GENERATION — Text Synthesis
# ============================================================================

def _sample_len(dist: Counter, rng: random.Random) -> int:
    lengths = list(dist)
    weights = [dist[l] for l in lengths]
    return max(2, min(rng.choices(lengths, weights=weights, k=1)[0], 16))


def _generate_word(
    section: str,
    stats: CorpusStats,
    rng: random.Random,
    target_len: int | None = None,
) -> list[int]:
    """Generate one synthetic Voynich word using section-specific statistics.

    Uses bigram transitions for local structure with unigram backoff when
    a transition is sparse. The initial token comes from the section's
    initial-position distribution. This produces words that match the
    section's bigram entropy while the recency buffer (in generate_section)
    handles the word-level repetition pattern.
    """
    sd = stats.length_dist.get(section)
    if not sd:
        sd = Counter()
        for s in stats.length_dist.values():
            sd.update(s)
    length = target_len or _sample_len(sd, rng)
    pos    = stats.pos_freq.get(section, stats.pos_freq.get('botanical', {}))
    bgrams = stats.bigrams.get(section, stats.bigrams.get('botanical', {}))
    uni    = stats.unigram.get(section, stats.unigram.get('botanical', Counter()))

    # Build unigram backoff for sparse transitions
    uni_total = sum(uni.values())
    uni_prob = {t: c / uni_total for t, c in uni.items()} if uni_total else {}

    # Initial token from section's initial-position distribution
    init_c = pos.get('initial', Counter()) if pos else Counter()
    if init_c:
        toks, wts = zip(*init_c.items())
        current = rng.choices(list(toks), weights=list(wts), k=1)[0]
    elif uni_prob:
        toks, wts = zip(*uni_prob.items())
        current = rng.choices(list(toks), weights=list(wts), k=1)[0]
    else:
        current = rng.randint(0, 11)
    word = [current]

    for i in range(1, length):
        is_final = (i == length - 1)
        row = bgrams.get(current, {})

        if is_final and pos.get('final'):
            final_c = pos['final']
            candidates = list(set(row.keys()) | set(final_c.keys()) | set(uni_prob.keys()))
            wts = []
            for t in candidates:
                p_row = row.get(t, 0)
                p_final = final_c.get(t, 0)
                p_uni = uni_prob.get(t, 1e-6)
                # Blend row transition with final-position weight, unigram backoff
                w = p_row + 0.3 * p_final + 0.05 * p_uni
                wts.append(max(w, 1e-10))
        elif row:
            candidates = list(row.keys())
            # Small unigram backoff for robustness
            wts = [row.get(t, 0) + 0.01 * uni_prob.get(t, 1e-6) for t in candidates]
        else:
            # Fallback: unigram sample
            candidates = list(uni_prob.keys()) if uni_prob else [0]
            wts = [uni_prob.get(t, 1.0) for t in candidates]

        total = sum(wts)
        if total > 0:
            current = rng.choices(candidates, weights=[w / total for w in wts], k=1)[0]
        else:
            current = rng.randint(0, 11)
        word.append(current)

    return word


def _build_vocab(
    section: str,
    n_types: int,
    stats: CorpusStats,
    rng: random.Random,
    zipf_alpha: float = 1.04,
) -> tuple[list[tuple], list[float]]:
    """Pre-generate n_types distinct word types with Zipf-distributed weights."""
    vocab: set[tuple] = set()
    attempts = 0
    while len(vocab) < n_types and attempts < n_types * 30:
        w = tuple(_generate_word(section, stats, rng))
        vocab.add(w)
        attempts += 1
    word_types = list(vocab)
    rng.shuffle(word_types)
    weights = [1.0 / (i + 1) ** zipf_alpha for i in range(len(word_types))]
    total = sum(weights)
    return word_types, [w / total for w in weights]


def generate_section(
    section: str,
    n_words: int,
    stats: CorpusStats,
    rng: random.Random,
    vocab_size: int = 1500,
    novelty_rate: float = 0.008,
) -> list[list[int]]:
    """Generate synthetic Voynich text with section-specific statistics.

    On-the-fly generation with two-tier vocabulary buffer.
    Every word is generated directly from section statistics (bigram
    transitions + positional distributions), preserving section-specific
    unigram distributions (verified KL match in v5).

    The recency buffer produces the Voynich's ~0.40 window-10 repetition
    rate. The repeat probability controls the global TTR: higher repeat_prob
    → lower TTR (more repetition), lower repeat_prob → higher TTR.

    Empirically calibrated:
      p_vocab=0.55, p_recency=0.25, p_fresh=0.20
      vocab_max=400, recency_max=12, rank-weighted Zipf sampling
      → TTR ≈ 0.14, repetition ≈ 0.38, Zipf ≈ 1.0, KL preserved
    """
    # Two-tier repetition buffer with frequency weighting:
    # Tier 1 — Vocab buffer: ALL unique word types seen so far (up to max).
    #   Sampled by RANK (Zipf weighting, not frequency) → preserves natural
    #   Zipf distribution without Yule-Simon runaway concentration.
    #   Rank 1 (most frequent) gets weight 1/1, rank 2 gets 1/2, etc.
    # Tier 2 — Recency buffer: last ~12 words for local repetition.
    #
    # Sampling: 60% vocab (rank-weighted), 25% recency, 15% fresh.
    vocab_buffer: list[tuple] = []  # list of (word_tokens, count)
    vocab_max = 400
    recency_buffer: list[list[int]] = []
    recency_max = 12

    p_vocab = 0.60    # from global vocab buffer (rank-weighted Zipf)
    p_recency = 0.25  # from local recency buffer
    p_fresh = 0.15    # new word from section stats

    # Internal: word → index in vocab_buffer for fast lookup
    vocab_index: dict[tuple, int] = {}

    words: list[list[int]] = []
    for i in range(n_words):
        r = rng.random()
        if vocab_buffer and r < p_vocab:
            # Tier 1: rank-weighted Zipf sample from vocab buffer
            # Sort by count descending, weight by 1/rank
            vocab_buffer.sort(key=lambda x: x[1], reverse=True)
            ranks = [1.0 / (j + 1) for j in range(len(vocab_buffer))]
            total_rank = sum(ranks)
            rank_probs = [rk / total_rank for rk in ranks]
            idx = rng.choices(range(len(vocab_buffer)), weights=rank_probs, k=1)[0]
            wt_list, cnt = vocab_buffer[idx]
            w = list(wt_list)
            # Update count
            vocab_buffer[idx] = (wt_list, cnt + 1)
        elif recency_buffer and r < p_vocab + p_recency:
            # Tier 2: local repetition — bias toward most recent
            idx = len(recency_buffer) - 1 - int(abs(rng.gauss(0, 1.5)))
            idx = max(0, min(idx, len(recency_buffer) - 1))
            w = list(recency_buffer[idx])
        else:
            # Tier 3: fresh word from section statistics
            w = list(_generate_word(section, stats, rng))
            # Add to vocab buffer (FIFO eviction)
            wt = tuple(w)
            if wt in vocab_index:
                # Word already in buffer — increment count
                vi = vocab_index[wt]
                wt_list, cnt = vocab_buffer[vi]
                vocab_buffer[vi] = (wt_list, cnt + 1)
            else:
                # New word — add to buffer
                vocab_buffer.append((wt, 1))
                vocab_index[wt] = len(vocab_buffer) - 1
                if len(vocab_buffer) > vocab_max:
                    # Evict oldest
                    old_wt, _ = vocab_buffer.pop(0)
                    del vocab_index[old_wt]
                    # Rebuild indices
                    vocab_index = {tup: j for j, (tup, _) in enumerate(vocab_buffer)}

        words.append(w)
        recency_buffer.append(w)
        if len(recency_buffer) > recency_max:
            recency_buffer.pop(0)

    return words


# ============================================================================
# RENDERING — Shavian and EVA output
# ============================================================================

def render_shavian(words: list[list[int]], words_per_line: int = 8) -> str:
    """Render token lists as Shavian text (12 glyphs only — the proof mode)."""
    lines: list[str] = []
    buf: list[str] = []
    for w in words:
        chars = []
        for t in w:
            if t in TOKEN_TO_SHAVIAN:
                chars.append(TOKEN_TO_SHAVIAN[t])
        if chars:
            buf.append(''.join(chars))
        if len(buf) >= words_per_line:
            lines.append(' '.join(buf))
            buf = []
    if buf:
        lines.append(' '.join(buf))
    return '\n'.join(lines)


def render_shavian_full(words: list[list[int]], words_per_line: int = 8) -> str:
    """Render token lists using the FULL Shavian inventory (30+ glyphs)."""
    lines: list[str] = []
    buf: list[str] = []
    for w in words:
        chars = [TOKEN_TO_SHAVIAN_FULL.get(t, FALLBACK_SHAVIAN) for t in w]
        buf.append(''.join(chars))
        if len(buf) >= words_per_line:
            lines.append(' '.join(buf))
            buf = []
    if buf:
        lines.append(' '.join(buf))
    return '\n'.join(lines)


def render_eva(words: list[list[int]], words_per_line: int = 8) -> str:
    """Render token lists as EVA glyph text (human-readable Voynich notation)."""
    lines: list[str] = []
    buf: list[str] = []
    for w in words:
        chars = []
        for t in w:
            g = TOKEN_TO_GLYPH.get(t)
            if g is None:
                g = '?'  # unknown fallback
            chars.append(g)
        buf.append(''.join(chars))
        if len(buf) >= words_per_line:
            lines.append('.'.join(buf))
            buf = []
    if buf:
        lines.append('.'.join(buf))
    return '\n'.join(lines)

